# AI providers — FakeProvider is default. OpenAI is opt-in (W4-S3).
# Keep OPENAI_API_KEY in .env.local (gitignored). Toggle live calls without removing the key:
OPENAI_ENABLED=false
# Optional override: fake | openai (overrides OPENAI_ENABLED)
# AI_PROVIDER=fake
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Supabase - blocked until persistence/share phases
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App config
NEXT_PUBLIC_APP_URL=
